[Unit]
Description=Lerd DNS (dnsmasq)
After=network.target

[Container]
Image=alpine:latest
ContainerName=lerd-dns
PublishPort=127.0.0.1:5300:5300/udp
PublishPort=127.0.0.1:5300:5300/tcp
Exec=/bin/sh -c "apk add --no-cache dnsmasq 2>/dev/null && dnsmasq --no-daemon --port=5300 --no-resolv --address=/.test/127.0.0.1"

[Service]
Restart=always

[Install]
WantedBy=default.target
